# ============================================================

# Gitignore - Homelab / Docker / Automation

# ============================================================

# ------------------------------------------------------------

# Entorno y secretos

# ------------------------------------------------------------

**/.env
**/.env.local
**/.env.*.local
**/*.env

# Mantener ejemplos versionados

!**/.env.example
!**/*.env.example

# Secretos / credenciales / certificados

**/secrets/
**/secret/
**/credentials/
**/certs/
**/certificates/
**/acme/
**/letsencrypt/
**/*.pem
**/*.key
**/*.crt
**/*.p12
**/*.pfx
**/*token*
**/*secret*
**/*password*
**/*credential*

# ------------------------------------------------------------

# Datos persistentes de contenedores

# ------------------------------------------------------------

**/data/
**/config/
**/storage/
**/uploads/
**/downloads/
**/media-data/
**/db/
**/database/
**/postgres/
**/mysql/
**/mariadb/
**/redis/
**/logs/
**/log/

# Excepción: si algún proyecto tiene configs de ejemplo

!**/config.example/
!**/config/**/*.example
!**/config/**/*.sample

# ------------------------------------------------------------

# Backups y copias manuales

# ------------------------------------------------------------

*.bak
*.bkp
*.backup
*.old
*.orig
*.tmp
*.temp
*~
*.swp
*.swo

# Backups concretos tipo compose.yaml.bkp

**/*.yaml.bkp
**/*.yml.bkp
**/*.json.bkp
**/*.md.bkp

# ------------------------------------------------------------

# Archivos privados/personales del proyecto

# ------------------------------------------------------------

**/sugerencias.md
**/SUGERENCIAS.md
**/notas.md
**/NOTAS.md
**/todo-private.md
**/private.md
/ports
/ports/

# ------------------------------------------------------------

# Sistema operativo

# ------------------------------------------------------------

.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db
$RECYCLE.BIN/

# ------------------------------------------------------------

# Editores / IDE

# ------------------------------------------------------------

.vscode/*
!.vscode/extensions.json
!.vscode/settings.example.json
.idea/
*.code-workspace

# ------------------------------------------------------------

# Python / scripts auxiliares

# ------------------------------------------------------------

**pycache**/
*.py[cod]
*.pyo
*.pyd
.venv/
venv/
env/
.envrc
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ------------------------------------------------------------

# Node / herramientas web

# ------------------------------------------------------------

node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
dist/
build/
.cache/

# ------------------------------------------------------------

# Logs generales

# ------------------------------------------------------------

*.log
logs/
log/

# ------------------------------------------------------------

# Mantener documentación importante para Codex y humanos

# ------------------------------------------------------------

!AGENTS.md
!README.md
!docs/
!docs/codex/
!docs/codex/**
!**/README.md
!**/.gitkeep
