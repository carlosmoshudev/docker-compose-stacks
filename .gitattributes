# ============================================================
# Git attributes - Homelab / Docker / Automation
# ============================================================

# Normalize text files and keep LF line endings.
* text=auto eol=lf

# Markdown / docs
*.md text eol=lf
*.txt text eol=lf

# Docker / YAML / env
compose.yaml text eol=lf
compose.yml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.env.example text eol=lf
Dockerfile text eol=lf
*.dockerfile text eol=lf

# Scripts
*.sh text eol=lf
*.bash text eol=lf
*.ps1 text eol=lf
*.psm1 text eol=lf
*.psd1 text eol=lf

# Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf

# Config formats
*.json text eol=lf
*.jsonc text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.conf text eol=lf
*.service text eol=lf

# Images / binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.zip binary
*.7z binary
*.tar binary
*.gz binary
*.sqlite binary
*.db binary