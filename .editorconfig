root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.{json,jsonc}]
indent_style = space
indent_size = 2

[*.{sh,bash}]
indent_style = space
indent_size = 2
end_of_line = lf

[*.{ps1,psm1,psd1}]
indent_style = space
indent_size = 2
end_of_line = lf

[*.{bat,cmd}]
end_of_line = crlf

[Makefile]
indent_style = tab